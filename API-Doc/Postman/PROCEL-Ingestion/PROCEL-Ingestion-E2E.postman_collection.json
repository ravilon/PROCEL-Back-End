      "name": "00 - Setup window (from/to)",
      "item": [
        {
          "name": "Set fromIso/toIso (last 10 minutes)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Define janela de consulta: ÃƒÂºltimos 10 minutos",
                  "const to = new Date();",
                  "const from = new Date(to.getTime() - 10*60*1000);",
                  "pm.collectionVariables.set('toIso', to.toISOString().replace(/\\.\\d{3}Z$/, 'Z'));",
                  "pm.collectionVariables.set('fromIso', from.toISOString().replace(/\\.\\d{3}Z$/, 'Z'));",
                  "",
                  "console.log('fromIso=', pm.collectionVariables.get('fromIso'));",
                  "console.log('toIso=', pm.collectionVariables.get('toIso'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
